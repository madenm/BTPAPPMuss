# ===========================================
# TitanBtp - Variables d'environnement
# ===========================================
# Copie ce fichier en .env ou .env.local et remplis les valeurs.
# Ne commite jamais .env ou .env.local (ils contiennent des secrets).

# ---------- Supabase (obligatoire) ----------
# URL du projet Supabase (Settings > API > Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Clé publique anon (Settings > API > Legacy anon, service_role > anon)
# Ou nouvelle clé "Publishable" selon ton projet Supabase
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Clé service_role (Settings > API > Legacy > service_role) - SERVEUR UNIQUEMENT
SUPABASE_SERVICE_KEY=your_service_role_key

# Obligatoire sur Vercel pour l'API : l'API serverless n'a pas accès à VITE_* au runtime.
# Mettez la MÊME valeur que VITE_SUPABASE_URL (ex: https://iaadzfvqmjqhalfybxok.supabase.co)
SUPABASE_URL=

# ---------- Staging (pour tester sans toucher à la prod) ----------
# Pour utiliser la BDD Staging en local, crée .env.local avec :
#   VITE_SUPABASE_URL=https://iaadzfvqmjqhalfybxok.supabase.co
#   VITE_SUPABASE_ANON_KEY=<ta clé publishable ou anon du projet Staging>
#   SUPABASE_SERVICE_KEY=<ta clé secret du projet Staging>
# L'URL et les clés se trouvent dans Supabase > projet Staging TitanBTP > Settings > API

# ---------- Base PostgreSQL (si utilisé par Drizzle / server/db) ----------
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres

# ---------- Email (Resend) ----------
RESEND_API_KEY=
SENDER_EMAIL=
RESEND_FROM=

# ---------- IA (optionnel) ----------
GEMINI_API_KEY=
OPENAI_API_KEY=
# Quota journalier d'utilisations IA par utilisateur (devis + estimation + analyse photo). Défaut : 10
AI_DAILY_LIMIT_PER_USER=10

# ---------- Admin ----------
VITE_ADMIN_EMAIL=
ADMIN_EMAIL=

# ---------- API (optionnel) ----------
# URL de base de l'API (ex: https://votre-app.vercel.app). En prod, à définir si le front est servi depuis un autre domaine.
# VITE_API_URL=
