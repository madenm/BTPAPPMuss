# ===========================================
# TitanBtp - Variables d'environnement
# ===========================================
# Copie en .env.local et remplace les placeholders par tes vraies valeurs.
# Ne commite jamais .env ou .env.local (secrets).

# ---------- Supabase (obligatoire pour le front) ----------
VITE_SUPABASE_URL=https://iaadzfvqmjqhalfybxok.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# ---------- Supabase serveur (obligatoire pour l'API / Vercel) ----------
SUPABASE_URL=https://iaadzfvqmjqhalfybxok.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# ---------- Optionnel ----------
# Email (Resend) — envoi d'emails
RESEND_API_KEY=re_xxxxxxxxxxxx
SENDER_EMAIL=notifications@tondomaine.com
RESEND_FROM=TitanBtp <notifications@tondomaine.com>

# IA — devis / estimation / analyse photo (Gemini ou OpenAI)
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=sk-xxxxxxxxxxxx
AI_DAILY_LIMIT_PER_USER=10

# Admin — email du compte admin (accès "Créer un compte")
VITE_ADMIN_EMAIL=admin@tondomaine.com
ADMIN_EMAIL=admin@tondomaine.com

# API externe — si le front appelle une API sur un autre domaine
VITE_API_URL=https://api.tondomaine.com

# PostgreSQL (si Drizzle / server/db)
DATABASE_URL=postgresql://postgres:password@db.iaadzfvqmjqhalfybxok.supabase.co:5432/postgres
